{
  "scene_type": "function_plot",
  "canvas": {
    "width": 400,
    "height": 400,
    "x_min": -4,
    "x_max": 4,
    "y_min": -4,
    "y_max": 8
  },
  "style": {
    "theme": "light",
    "stroke_color": "#333333",
    "fill_color": "none",
    "font_size": 12,
    "font_family": "sans-serif"
  },
  "objects": [
    {
      "type": "function_curve",
      "id": "linear",
      "expression": "2*x + 1",
      "x_min": -4,
      "x_max": 4
    },
    {
      "type": "point",
      "id": "root",
      "x": -0.5,
      "y": 0,
      "label": "(-0.5, 0)"
    },
    {
      "type": "point",
      "id": "y_intercept",
      "x": 0,
      "y": 1,
      "label": "(0, 1)"
    }
  ],
  "constraints": [],
  "annotations": [
    {
      "type": "label",
      "id": "ann_expr",
      "text": "y = 2x + 1",
      "anchor": "y_intercept",
      "dx": 0.3,
      "dy": 0.5
    }
  ]
}
