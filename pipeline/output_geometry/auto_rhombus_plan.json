    {
      "text": "Угол $AMD = 90°$. Треугольник $ABD$ равнобедренный. $AO$ и $DM$ — его высоты.",
      "objects": [],
      "annotations": [
        {
          "type": "label",
          "id": "lbl_AO",
          "text": "AO",
          "anchor": "O",
          "dx": -0.5,
          "dy": 0.5,
