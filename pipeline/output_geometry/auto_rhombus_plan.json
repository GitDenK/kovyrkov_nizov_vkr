          "font_size": 12
        }
      ],
      "constraints": [],
      "caption": "Высоты AO и DM"
    },
    {
      "text": "Из треугольника $AMD$: $MD^2 = AD^2 - AM^2 = 12 - \\frac{4}{3} = \\frac{32}{3}$, $MD = \\frac{4\\sqrt{6}}{3}$.",
      "objects": [],
      "annotations": [
        {
          "type": "label",
          "id": "lbl_MD",
          "text": "MD = \\frac{4\\sqrt{6}}{3}",
          "anchor": "M",
          "dx": 0.5,
          "dy": -0.5,
          "color": "#8e44ad",
          "font_size": 12
        }
      ],
      "constraints": [],
      "caption": "Длина MD"
    },
    {
      "text": "Из треугольника $BMD$: $BD^2 = BM^2 + MD^2 = \\frac{48}{9} + \\frac{32}{3} = \\frac{144}{9} = 16$, $BD = 4$.",
      "objects": [],
      "annotations": [
        {
          "type": "label",
          "id": "lbl_BD",
          "text": "BD = 4",
          "anchor": "B",
          "dx": 0.5,
          "dy": -0.5,
          "color": "#e67e22",
          "font_size": 12
        }
      ],
      "constraints": [],
      "caption": "Длина BD"
    },
    {
      "text": "Площадь треугольника $ABD$: $S(ABD) = \\frac{1}{2}AB \\cdot MD = \\frac{1}{2}BD \\cdot AO$. Отсюда $AO = \\frac{AB \\cdot MD}{BD} = \\frac{2\\sqrt{3} \\cdot 4\\sqrt{2/3}}{4} = 2\\sqrt{2}$.",
      "objects": [],
      "annotations": [
        {
          "type": "label",
          "id": "lbl_AO",
          "text": "AO = 2\\sqrt{2}",
          "anchor": "O",
          "dx": -0.5,
          "dy": 0.5,
          "color": "#27ae60",
          "font_size": 12
        }
      ],
      "constraints": [],
      "caption": "Длина AO"
    },
    {
      "text": "Диагональ $AC = 2AO = 4\\sqrt{2}$.",
