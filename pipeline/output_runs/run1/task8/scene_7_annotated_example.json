{
  "scene_type": "diagram",
  "canvas": {
    "width": 500,
    "height": 300,
    "x_min": 0,
    "x_max": 500,
    "y_min": 0,
    "y_max": 300
  },
  "style": {
    "theme": "light",
    "stroke_color": "#333333",
    "fill_color": "#f5f5f5",
    "font_size": 13,
    "font_family": "sans-serif"
  },
  "objects": [
    {
      "type": "title",
      "id": "title",
      "text": "Пошаговое решение задачи на нахождение производной по наклону касательной"
    },
    {
      "type": "box",
      "id": "problem",
      "text": "Задача: На графике функции $y = f(x)$ проведена касательная в точке $x = 2$. Найдите $f'(2)$.",
      "style": {
        "fill": "#fdebd0",
        "stroke": "#e67e22"
      }
    },
    {
      "type": "formula_block",
      "id": "expr_0",
      "formula": "$y = 3 при x = 2$"
    },
    {
      "type": "arrow",
      "id": "arr_e_0",
      "from_point": "problem",
      "to_point": "expr_0"
    },
    {
      "type": "box",
      "id": "ann_0",
      "text": "Точка касания (2, 3)"
    },
    {
      "type": "arrow",
      "id": "arr_a_0",
      "from_point": "expr_0",
      "to_point": "ann_0"
    },
    {
      "type": "formula_block",
      "id": "expr_1",
      "formula": "$Касательная идёт из точки (2, 3) в точку (4, 7)$"
    },
    {
      "type": "arrow",
      "id": "arr_e_1",
      "from_point": "ann_0",
      "to_point": "expr_1"
    },
    {
      "type": "box",
      "id": "ann_1",
      "text": "Другая точка касательной (4, 7)"
    },
    {
      "type": "arrow",
      "id": "arr_a_1",
      "from_point": "expr_1",
      "to_point": "ann_1"
    },
    {
      "type": "formula_block",
      "id": "expr_2",
      "formula": "$\\Delta x = 4 - 2 = 2$"
    },
    {
      "type": "arrow",
      "id": "arr_e_2",
      "from_point": "ann_1",
      "to_point": "expr_2"
    },
    {
      "type": "box",
      "id": "ann_2",
      "text": "Расстояние по горизонтали"
    },
    {
      "type": "arrow",
      "id": "arr_a_2",
      "from_point": "expr_2",
      "to_point": "ann_2"
    },
    {
      "type": "formula_block",
      "id": "expr_3",
      "formula": "$\\Delta y = 7 - 3 = 4$"
    },
    {
      "type": "arrow",
      "id": "arr_e_3",
      "from_point": "ann_2",
      "to_point": "expr_3"
    },
    {
      "type": "box",
      "id": "ann_3",
      "text": "Расстояние по вертикали"
    },
    {
      "type": "arrow",
      "id": "arr_a_3",
      "from_point": "expr_3",
      "to_point": "ann_3"
    },
    {
      "type": "formula_block",
      "id": "expr_4",
      "formula": "$f'(2) = \\frac{\\Delta y}{\\Delta x} = \\frac{4}{2} = 2$"
    },
    {
      "type": "arrow",
      "id": "arr_e_4",
      "from_point": "ann_3",
      "to_point": "expr_4"
    },
    {
      "type": "box",
      "id": "ann_4",
      "text": "Вычисление производной"
    },
    {
      "type": "arrow",
      "id": "arr_a_4",
      "from_point": "expr_4",
      "to_point": "ann_4"
    }
  ],
  "constraints": [],
  "annotations": []
}